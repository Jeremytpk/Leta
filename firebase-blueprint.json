{
  "entities": {
    "branch": {
      "title": "Branch Company",
      "description": "A branch business unit of Bora Holding corporate parent",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique branch identifier" },
        "name": { "type": "string", "description": "Branch company name, e.g. Leta Technologies LLC" },
        "address": { "type": "string", "description": "Branch street address" },
        "city": { "type": "string", "description": "City where branch is located" },
        "state": { "type": "string", "description": "US state, typically GA" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Document creation timestamp" }
      },
      "required": ["id", "name", "address", "city", "state"]
    },
    "employee": {
      "title": "Employee Profile",
      "description": "System user account with specific role-based permissions",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase auth UID or dynamic identifier" },
        "email": { "type": "string", "description": "Corporate or employee email" },
        "fullName": { "type": "string", "description": "Full name of the technician or administrator" },
        "branchId": { "type": "string", "description": "Branch division they represent, e.g. Leta Tech" },
        "role": { "type": "string", "enum": ["sup_admin", "employee"], "description": "System access role" },
        "phone": { "type": "string", "description": "Contact phone number" },
        "hourlyRate": { "type": "number", "description": "Default compensation per hour worked" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Profile registration time" },
        "status": { "type": "string", "enum": ["active", "pending"], "description": "Account activation status" },
        "photoURL": { "type": "string", "description": "Base64 or URL profile image data" },
        "isOnline": { "type": "boolean", "description": "Real-time connection indicator" },
        "isOnBreak": { "type": "boolean", "description": "Break state indicator" },
        "breakStartedAt": { "type": "string", "format": "date-time", "description": "Current break starting timestamp" },
        "breakEndedAt": { "type": "string", "format": "date-time", "description": "Most recently completed break ending timestamp" }
      },
      "required": ["uid", "email", "fullName", "branchId", "role"]
    },
    "job": {
      "title": "Service Job Ticket",
      "description": "Client requested troubleshoot, installation, or maintenance job",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "branchId": { "type": "string" },
        "clientName": { "type": "string" },
        "clientAddress": { "type": "string" },
        "description": { "type": "string" },
        "assignedTechId": { "type": "string" },
        "assignedTechName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "onsite", "maintenance", "completed"] },
        "payType": { "type": "string", "enum": ["hourly", "flat"] },
        "payRate": { "type": "number" },
        "loggedHours": { "type": "number" },
        "grossPay": { "type": "number" },
        "taxFica": { "type": "number" },
        "taxState": { "type": "number" },
        "taxFederal": { "type": "number" },
        "netPay": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "startedAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "branchId", "clientName", "clientAddress", "description", "assignedTechId", "status", "payType", "payRate"]
    },
    "comment": {
      "title": "Ticket Comment",
      "description": "Technician update or communication regarding a service ticket",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "jobId": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorRole": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "jobId", "authorId", "authorName", "authorRole", "text"]
    },
    "chatMessage": {
      "title": "Live Chat Message",
      "description": "General coordinate message shared in the real-time company portal",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderRole": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "recipientId": { "type": "string", "description": "Target employee UID for private/segmented administrator - employee grouping" }
      },
      "required": ["id", "senderId", "senderName", "senderRole", "text"]
    },
    "paystub": {
      "title": "Employee Compensation Paystub",
      "description": "Autogenerated salary statement reflecting GA state and federal withholding deductions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "employeeId": { "type": "string" },
        "employeeName": { "type": "string" },
        "jobId": { "type": "string" },
        "jobDescription": { "type": "string" },
        "payDate": { "type": "string", "format": "date-time" },
        "grossPay": { "type": "number" },
        "taxFica": { "type": "number" },
        "taxState": { "type": "number" },
        "taxFederal": { "type": "number" },
        "netPay": { "type": "number" },
        "status": { "type": "string" }
      },
      "required": ["id", "employeeId", "employeeName", "jobId", "payDate", "grossPay", "netPay", "status"]
    }
  },
  "firestore": {
    "/branches/{branchId}": {
      "schema": "branch",
      "description": "Holding companies divisions and branch offices"
    },
    "/employees/{employeeId}": {
      "schema": "employee",
      "description": "Holding employee records and access keys"
    },
    "/users/{userId}": {
      "schema": "employee",
      "description": "Registered user credentials and client logins"
    },
    "/jobs/{jobId}": {
      "schema": "job",
      "description": "Client assigned tasks and dispatch tickets"
    },
    "/jobs/{jobId}/comments/{commentId}": {
      "schema": "comment",
      "description": "Chronological audit and diagnostic feed for tickets"
    },
    "/chats/{chatId}": {
      "schema": "chatMessage",
      "description": "Real-time coordinator internal chat channel"
    },
    "/paystubs/{paystubId}": {
      "schema": "paystub",
      "description": "Official compensation records with automatic tax calculations"
    }
  }
}
