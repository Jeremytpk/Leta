# GEMINI_API_KEY: Required for Gemini AI API calls.
# Automatically injected at runtime from secrets.
# Configure this via the secrets panel in the configuration.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this application is hosted.
# Automatically injected at runtime with the service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SMTP Mail Server Credentials (Optional)
# If provided, Leta Technologies LLC will transmit real technician dispatch notifications.
# If omitted, notifications will fallback to safe simulation mode, logging to server console.
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="your-smtp-username"
SMTP_PASS="your-smtp-password"
SMTP_FROM="noreply@example.com"
